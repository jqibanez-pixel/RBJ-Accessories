# Add MIME type for GLB files
AddType model/gltf-binary .glb
Options -Indexes

# Legacy customizer route fallback
Redirect 301 /rbjsystem/USER/test_customize.php /rbjsystem/USER/customize.php
Redirect 301 /rbjsystem/ADMIN/product_reviews_admin.php /rbjsystem/ADMIN/feedback_admin.php

<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"

    # Enable CORS for GLB files
    <Files "*.glb">
        Header set Access-Control-Allow-Origin "*"
        Header set Access-Control-Allow-Methods "GET, OPTIONS"
        Header set Access-Control-Allow-Headers "Range"
    </Files>
</IfModule>

<FilesMatch "(^\.|\.env$|composer\.(json|lock)$|package(-lock)?\.json$|yarn\.lock$|pnpm-lock\.yaml$|\.sql$|\.bak$|\.log$)">
    Require all denied
</FilesMatch>

